{
  "name": "markdown-editor-app",
  "version": "2.2.2",
  "description": "Angular + Electron Markdown Editor",
  "main": "public/electron.js",
  "homepage": "https://github.com/JubinSaniei/MarkdownEditor",
  "scripts": {
    "start": "ng serve",
    "build": "ng build",
    "electron": "electron .",
    "electron-dev": "concurrently \"ng serve\" \"wait-on http://localhost:4200 && electron .\"",
    "electron-dev:4201": "concurrently \"ng serve --port 4201\" \"wait-on http://localhost:4201 && electron .\"",
    "electron-dev:4202": "concurrently \"ng serve --port 4202\" \"wait-on http://localhost:4202 && electron .\"",
    "build-electron": "ng build --configuration production && electron-builder",
    "dist": "npm run build && electron-builder --publish=never",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0"
  },
  "keywords": [
    "angular",
    "electron",
    "markdown",
    "editor"
  ],
  "author": {
    "name": "Jubin",
    "email": "jubin.saniei@gmail.com"
  },
  "license": "MIT",
  "dependencies": {
    "@angular/animations": "^20.2.1",
    "@angular/common": "^20.2.1",
    "@angular/compiler": "^20.2.1",
    "@angular/core": "^20.2.1",
    "@angular/forms": "^20.2.1",
    "@angular/platform-browser": "^20.2.1",
    "@angular/platform-browser-dynamic": "^20.2.1",
    "@angular/router": "^20.2.1",
    "@anthropic-ai/sdk": "^0.52.0",
    "@aws-sdk/client-bedrock-runtime": "^3.800.0",
    "@aws-sdk/credential-providers": "^3.800.0",
    "dompurify": "^3.3.1",
    "highlight.js": "^11.11.1",
    "marked": "^16.2.1",
    "openai": "^4.104.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.2.0",
    "@angular/cli": "^20.2.0",
    "@angular/compiler-cli": "^20.2.1",
    "@types/dompurify": "^3.0.5",
    "@types/highlight.js": "^9.12.4",
    "@types/marked": "^5.0.2",
    "@types/node": "^24.3.0",
    "concurrently": "^9.2.1",
    "electron": "^37.3.1",
    "electron-builder": "^26.0.12",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "wait-on": "^8.0.4"
  },
  "build": {
    "appId": "com.example.markdowneditor",
    "productName": "Markdown Editor",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "public/electron.js",
      "public/preload.js",
      "src/assets/*.*"
    ],
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown File",
        "description": "Markdown Document",
        "role": "Editor",
        "icon": "src/assets/logo.png"
      },
      {
        "ext": "markdown",
        "name": "Markdown File",
        "description": "Markdown Document",
        "role": "Editor",
        "icon": "src/assets/logo.png"
      }
    ],
    "win": {
      "icon": "src/assets/logo.png",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "src/assets/android-chrome-512x512.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "icon": "src/assets/android-chrome-512x512.png",
      "target": "deb",
      "category": "Utility"
    },
    "portable": {
      "artifactName": "MarkdownEditor-Portable.exe"
    },
    "nsis": {
      "artifactName": "MarkdownEditor-Setup.exe",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "forceCodeSigning": false,
    "buildDependenciesFromSource": false
  }
}
